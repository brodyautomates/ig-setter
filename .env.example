# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from: supabase.com → your project → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Webhook Security ────────────────────────────────────────────────────────
# Make up a long random string — must match in both .env.local and n8n env vars
WEBHOOK_SECRET=make-up-a-long-random-string-here
# Must match what you enter in Meta Developer Portal → Webhooks → Verify Token
WEBHOOK_VERIFY_TOKEN=make-up-another-random-string-here

# ─── Instagram / Meta Graph API ──────────────────────────────────────────────
# Get from: developers.facebook.com → your app → Instagram → Generate Token
INSTAGRAM_ACCESS_TOKEN=your-long-lived-instagram-access-token
INSTAGRAM_USER_ID=your-ig-user-id

# ─── n8n ─────────────────────────────────────────────────────────────────────
# The override webhook URL from your n8n instance (path: ig-dm-override)
N8N_OVERRIDE_WEBHOOK_URL=https://your-n8n-instance.com/webhook/ig-dm-override

# ─── Anthropic (Claude API) ──────────────────────────────────────────────────
# Claude is called from n8n — add your key there. This is a placeholder.
ANTHROPIC_API_KEY=sk-ant-your-key-here
